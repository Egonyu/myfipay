# myFiBase environment template — copy to .env and fill in. NEVER commit .env.

POSTGRES_DB=myfibase
POSTGRES_USER=myfibase
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

REDIS_PASSWORD=
REDIS_PORT=6379

APP_ENV=development
APP_PORT=8080
APP_SECRET=            # openssl rand -hex 32

# JWT (optional — falls back to APP_SECRET / 24h)
# JWT_SECRET=
# JWT_EXPIRY_HOURS=24

ZENGAPAY_API_URL=https://api.sandbox.zengapay.com
ZENGAPAY_API_TOKEN=
ZENGAPAY_WEBHOOK_SECRET=

ADMINER_PORT=8081

# Watchdog push alerts (scripts/watchdog.sh) — random secret ntfy.sh topic;
# subscribe to it in the ntfy app to receive DOWN/RECOVERED alerts
WATCHDOG_NTFY_TOPIC=

# CORS: pinned dashboard origins (comma-separated). Empty + APP_ENV=development
# echoes any origin for local tooling; empty in production sends no CORS headers.
CORS_ALLOWED_ORIGINS=https://myfipay.com,https://www.myfipay.com
# ZengaPay webhook source-IP allowlist (IPs/CIDRs, comma-separated).
# Empty = disabled (sandbox). Set once ZengaPay prod IPs are known.
ZENGAPAY_WEBHOOK_IPS=
